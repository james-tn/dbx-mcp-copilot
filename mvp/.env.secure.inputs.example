AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-daily-account-planner-secure
AZURE_LOCATION=eastus2
SECURE_DEPLOYMENT=true
DEPLOYMENT_MODE=secure
INFRA_NAME_PREFIX=dailyacctplannersec
SELLER_A_UPN=
SELLER_B_UPN=

# Optional: set this when you need delegated Graph device-code auth instead of the
# Azure CLI Graph token during the M365 bootstrap step.
M365_GRAPH_PUBLISHER_CLIENT_ID=

# Optional: override the starter Azure OpenAI deployment footprint when your
# tenant uses a different quota profile.
# AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
# AZURE_OPENAI_MODEL=gpt-5.2-chat
# AZURE_OPENAI_MODEL_NAME=gpt-5.2-chat
# AZURE_OPENAI_MODEL_VERSION=2026-02-10
# AZURE_OPENAI_DEPLOYMENT_CAPACITY=500

# Existing Databricks production mode:
# Fill these when the planner should use an already-existing Databricks workspace
# and customer-owned AIQ tables instead of a mock seeded environment.
CUSTOMER_DATABRICKS_HOST=
CUSTOMER_DATABRICKS_AZURE_RESOURCE_ID=
CUSTOMER_DATABRICKS_OBO_SCOPE=2ff814a6-3304-4ab8-85cb-cd0e6f879c1d/.default
CUSTOMER_DATABRICKS_WAREHOUSE_ID=
CUSTOMER_TOP_OPPORTUNITIES_SOURCE=prod_catalog.data_science_account_iq_gold.account_iq_scores
CUSTOMER_CONTACTS_SOURCE=prod_catalog.account_iq_gold.aiq_contact
# Optional when sf_vpower_bronze is not on the workspace default catalog:
# CUSTOMER_SCOPE_ACCOUNTS_CATALOG=
# CUSTOMER_SALES_TEAM_MAPPING_CATALOG=
CUSTOMER_REP_LOOKUP_STATIC_MAP_JSON_PATH=fixtures/customer_rep_lookup_static_map.json
