    },
    {
      "condition": "[parameters('secureDeployment')]",
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.cognitiveservices.azure.com",
      "location": "global"
    },
    {
      "condition": "[parameters('secureDeployment')]",
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.vaultcore.azure.net",
      "location": "global"
