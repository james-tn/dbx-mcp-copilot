    "acrId": {
      "type": "string",
      "value": "[if(parameters('createAcr'), resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '')]"
    },
    "vnetId": {
      "type": "string",
      "value": "[if(parameters('secureDeployment'), resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName')), '')]"
    },
    "acaSubnetId": {
      "type": "string",
      "value": "[if(parameters('secureDeployment'), resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('acaSubnetName')), '')]"
    },
    "databricksPublicSubnetId": {
