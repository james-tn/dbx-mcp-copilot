# Tracked operator input template for open mode.
# Copy this file to `mvp/.env.inputs` and edit the copy locally.
# Prefer canonical hosted-runtime names. Legacy `CUSTOMER_*` aliases are no
# longer the preferred documentation contract.

AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-daily-account-planner
AZURE_LOCATION=eastus
SECURE_DEPLOYMENT=false
DEPLOYMENT_MODE=open
INFRA_NAME_PREFIX=dailyacctplanneropen
SELLER_A_UPN=
SELLER_B_UPN=

# Optional: set this when you need delegated Graph device-code auth instead of the
# Azure CLI Graph token during the M365 bootstrap step.
M365_GRAPH_PUBLISHER_CLIENT_ID=

# Optional: override the starter Azure OpenAI deployment footprint when your
# tenant uses a different quota profile.
# AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
# AZURE_OPENAI_MODEL=gpt-5.2-chat
# AZURE_OPENAI_MODEL_NAME=gpt-5.2-chat
# AZURE_OPENAI_MODEL_VERSION=2026-02-10
# AZURE_OPENAI_DEPLOYMENT_CAPACITY=500

# Optional existing Databricks mode for local/open validation against customer data.
DATABRICKS_HOST=
DATABRICKS_AZURE_RESOURCE_ID=
DATABRICKS_OBO_SCOPE=2ff814a6-3304-4ab8-85cb-cd0e6f879c1d/.default
DATABRICKS_WAREHOUSE_ID=
TOP_OPPORTUNITIES_SOURCE=prod_catalog.data_science_account_iq_gold.account_iq_scores
CONTACTS_SOURCE=prod_catalog.account_iq_gold.aiq_contact
# Optional when sf_vpower_bronze is not on the workspace default catalog:
# SCOPE_ACCOUNTS_CATALOG=
# SALES_TEAM_MAPPING_CATALOG=
