# Shared
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-ri-poc
AZURE_LOCATION=eastus
BROKER_IMAGE=ghcr.io/your-org/ri-auth-broker:latest
MCP_IMAGE=ghcr.io/your-org/ri-revenue-mcp:latest
MCP_SERVICE_URL=

# Existing services
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
CREATE_DATABRICKS_WORKSPACE=true
DATABRICKS_WORKSPACE_NAME=ri-poc-dbx
DATABRICKS_WORKSPACE_SKU=premium
DATABRICKS_MANAGED_RG_NAME=ri-poc-dbx-mrg
CREATE_DATABRICKS_ACCESS_CONNECTOR=true
DATABRICKS_ACCESS_CONNECTOR_NAME=ri-poc-dbx-ucc

# Broker app registration
BROKER_CLIENT_ID=
BROKER_CLIENT_SECRET=
BROKER_CLIENT_SCOPE=2ff814a6-3304-4ab8-85cb-cd0e6f879c1d/.default
BROKER_EXPECTED_AUDIENCE=api://ri-mcp-api
BROKER_ALLOWED_TENANTS=
BROKER_ALLOWED_SERVICE_NAMES=revenue-mcp
BROKER_SHARED_SERVICE_KEY=

# MCP service
MCP_BROKER_BASE_URL=
MCP_BROKER_SHARED_KEY=
MCP_ALLOWED_SCHEMA=ri_poc.revenue
MCP_MAX_ROWS=5000
MCP_QUERY_TIMEOUT_SECONDS=30

# Optional: for local testing only
USER_ASSERTION_TOKEN=
