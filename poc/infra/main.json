{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "18042981341670528036"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "prefix": {
      "type": "string",
      "defaultValue": "ri-poc",
      "metadata": {
        "description": "POC environment name prefix."
      }
    },
    "brokerImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for Auth Broker service."
      }
    },
    "mcpImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for Revenue MCP service."
      }
    },
    "azureOpenAIEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Existing Azure OpenAI endpoint URL."
      }
    },
    "azureOpenAIDeployment": {
      "type": "string",
      "metadata": {
        "description": "Azure OpenAI deployment/model name."
      }
    },
    "databricksServerHostname": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Databricks SQL hostname, for example adb-xxxx.azuredatabricks.net."
      }
    },
    "databricksHttpPath": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Databricks SQL Warehouse HTTP path."
      }
    },
    "createDatabricksWorkspace": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create a new Premium Databricks workspace (UC-ready baseline)."
      }
    },
    "databricksWorkspaceName": {
      "type": "string",
      "defaultValue": "[format('{0}-dbx', parameters('prefix'))]",
      "metadata": {
        "description": "Name of the Databricks workspace to create when createDatabricksWorkspace=true."
      }
    },
    "databricksWorkspaceSku": {
      "type": "string",
      "defaultValue": "premium",
      "allowedValues": [
        "premium",
        "standard",
        "trial"
      ],
      "metadata": {
        "description": "SKU for Databricks workspace. Premium is required for Unity Catalog scenarios."
      }
    },
    "databricksManagedResourceGroupName": {
      "type": "string",
      "defaultValue": "[format('{0}-dbx-mrg', parameters('prefix'))]",
      "metadata": {
        "description": "Managed resource group name used by the Databricks workspace."
      }
    },
    "createDatabricksAccessConnector": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create Databricks Access Connector for Unity Catalog storage access patterns."
      }
    },
    "databricksAccessConnectorName": {
      "type": "string",
      "defaultValue": "[format('{0}-dbx-ucc', parameters('prefix'))]",
      "metadata": {
        "description": "Name of the Databricks Access Connector resource."
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "Entra tenant ID used for token validation."
      }
    },
    "brokerClientId": {
      "type": "string",
      "metadata": {
        "description": "Broker app registration client ID."
      }
    },
    "brokerClientSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Broker app registration client secret."
      }
    },
    "brokerExpectedAudience": {
      "type": "string",
      "metadata": {
        "description": "Audience expected in incoming user token by broker. Example: api://ri-mcp-api"
      }
    },
    "brokerAllowedTenants": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Comma-separated list of allowed tenant IDs for broker."
      }
    },
    "brokerSharedServiceKey": {
      "type": "securestring",
      "metadata": {
        "description": "Shared key used by MCP service when calling broker token endpoint."
      }
    },
    "mcpAllowedSchema": {
      "type": "string",
      "defaultValue": "ri_poc.revenue",
      "metadata": {
        "description": "Allowed schema for MCP SQL generation."
      }
    },
    "mcpMaxRows": {
      "type": "int",
      "defaultValue": 5000,
      "metadata": {
        "description": "Default query row limit in MCP service."
      }
    },
    "mcpQueryTimeoutSeconds": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Default query timeout in seconds for MCP service."
      }
    }
  },
  "variables": {
    "logAnalyticsName": "[format('{0}-law', parameters('prefix'))]",
    "appInsightsName": "[format('{0}-appi', parameters('prefix'))]",
    "containerEnvName": "[format('{0}-cae', parameters('prefix'))]",
    "brokerAppName": "[format('{0}-auth-broker', parameters('prefix'))]",
    "mcpAppName": "[format('{0}-revenue-mcp', parameters('prefix'))]"
  },
  "resources": [
    {
      "condition": "[parameters('createDatabricksAccessConnector')]",
      "type": "Microsoft.Databricks/accessConnectors",
      "apiVersion": "2023-05-01",
      "name": "[parameters('databricksAccessConnectorName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      }
    },
    {
      "condition": "[parameters('createDatabricksWorkspace')]",
      "type": "Microsoft.Databricks/workspaces",
      "apiVersion": "2024-05-01",
      "name": "[parameters('databricksWorkspaceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('databricksWorkspaceSku')]"
      },
      "properties": {
        "managedResourceGroupId": "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('databricksManagedResourceGroupName'))]"
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerEnvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2023-09-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('brokerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http"
          },
          "activeRevisionsMode": "Single",
          "secrets": [
            {
              "name": "broker-client-secret",
              "value": "[parameters('brokerClientSecret')]"
            },
            {
              "name": "broker-shared-service-key",
              "value": "[parameters('brokerSharedServiceKey')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "auth-broker",
              "image": "[parameters('brokerImage')]",
              "env": [
                {
                  "name": "AZURE_TENANT_ID",
                  "value": "[parameters('tenantId')]"
                },
                {
                  "name": "BROKER_CLIENT_ID",
                  "value": "[parameters('brokerClientId')]"
                },
                {
                  "name": "BROKER_CLIENT_SECRET",
                  "secretRef": "broker-client-secret"
                },
                {
                  "name": "BROKER_SCOPE",
                  "value": "2ff814a6-3304-4ab8-85cb-cd0e6f879c1d/.default"
                },
                {
                  "name": "BROKER_EXPECTED_AUDIENCE",
                  "value": "[parameters('brokerExpectedAudience')]"
                },
                {
                  "name": "BROKER_ALLOWED_TENANTS",
                  "value": "[parameters('brokerAllowedTenants')]"
                },
                {
                  "name": "BROKER_ALLOWED_SERVICE_NAMES",
                  "value": "revenue-mcp"
                },
                {
                  "name": "BROKER_SHARED_SERVICE_KEY",
                  "secretRef": "broker-shared-service-key"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
                }
              ],
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 2
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('mcpAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http"
          },
          "activeRevisionsMode": "Single",
          "secrets": [
            {
              "name": "broker-shared-service-key",
              "value": "[parameters('brokerSharedServiceKey')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "revenue-mcp",
              "image": "[parameters('mcpImage')]",
              "env": [
                {
                  "name": "MCP_BROKER_BASE_URL",
                  "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('brokerAppName')), '2024-03-01').configuration.ingress.fqdn)]"
                },
                {
                  "name": "MCP_BROKER_SHARED_KEY",
                  "secretRef": "broker-shared-service-key"
                },
                {
                  "name": "AZURE_OPENAI_ENDPOINT",
                  "value": "[parameters('azureOpenAIEndpoint')]"
                },
                {
                  "name": "AZURE_OPENAI_DEPLOYMENT",
                  "value": "[parameters('azureOpenAIDeployment')]"
                },
                {
                  "name": "DATABRICKS_SERVER_HOSTNAME",
                  "value": "[if(parameters('createDatabricksWorkspace'), coalesce(if(parameters('createDatabricksWorkspace'), string(reference(resourceId('Microsoft.Databricks/workspaces', parameters('databricksWorkspaceName')), '2024-05-01').workspaceUrl), ''), parameters('databricksServerHostname')), parameters('databricksServerHostname'))]"
                },
                {
                  "name": "DATABRICKS_HTTP_PATH",
                  "value": "[parameters('databricksHttpPath')]"
                },
                {
                  "name": "MCP_ALLOWED_SCHEMA",
                  "value": "[parameters('mcpAllowedSchema')]"
                },
                {
                  "name": "MCP_MAX_ROWS",
                  "value": "[string(parameters('mcpMaxRows'))]"
                },
                {
                  "name": "MCP_QUERY_TIMEOUT_SECONDS",
                  "value": "[string(parameters('mcpQueryTimeoutSeconds'))]"
                },
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
                }
              ],
              "resources": {
                "cpu": "[json('0.75')]",
                "memory": "1.5Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 2
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.App/containerApps', variables('brokerAppName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerEnvName'))]",
        "[resourceId('Microsoft.Databricks/workspaces', parameters('databricksWorkspaceName'))]"
      ]
    }
  ],
  "outputs": {
    "brokerUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('brokerAppName')), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "mcpUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('mcpAppName')), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "containerEnvironmentName": {
      "type": "string",
      "value": "[variables('containerEnvName')]"
    },
    "appInsightsName": {
      "type": "string",
      "value": "[variables('appInsightsName')]"
    },
    "databricksWorkspaceUrl": {
      "type": "string",
      "value": "[if(parameters('createDatabricksWorkspace'), format('https://{0}', if(parameters('createDatabricksWorkspace'), string(reference(resourceId('Microsoft.Databricks/workspaces', parameters('databricksWorkspaceName')), '2024-05-01').workspaceUrl), '')), '')]"
    },
    "databricksWorkspaceResourceId": {
      "type": "string",
      "value": "[if(parameters('createDatabricksWorkspace'), resourceId('Microsoft.Databricks/workspaces', parameters('databricksWorkspaceName')), '')]"
    },
    "databricksAccessConnectorResourceId": {
      "type": "string",
      "value": "[if(parameters('createDatabricksAccessConnector'), resourceId('Microsoft.Databricks/accessConnectors', parameters('databricksAccessConnectorName')), '')]"
    }
  }
}